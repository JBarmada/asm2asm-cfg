{
  "benchmark": "humaneval",
  "benchmark_root": "../cpu-transpiler-inference/benchmarks/humaneval-c",
  "composer_model": "gemini-3-flash-preview",
  "composer_prompt_config": "error_cfg_dfg",
  "model_name": "Qwen-3b",
  "max_workers": 10,
  "max_retries": 3,
  "retry_base_seconds": 2.0,
  "retry_jitter_seconds": 1.0,
  "startup_jitter_seconds": 2.0,
  "bootstrap_errors": true,
  "source_isa": "x86",
  "target_isa": "armv8-linux",
  "source_dataset_column": "x86_64",
  "cfg_dataset_column": "x86_64",
  "dfg_dataset_column": "x86_64",
  "graph_split": "O2",
  "clang": "clang-17",
  "compile_flags": [
    "-O2",
    "-target",
    "aarch64-linux-gnu"
  ],
  "link_flags": [
    "-O2",
    "-target",
    "aarch64-linux-gnu",
    "-static",
    "-fuse-ld=lld",
    "-lm"
  ],
  "qemu": "qemu-aarch64",
  "use_qemu": true,
  "timeout_seconds": 30,
  "standard_timeout_seconds": 30,
  "graph_source": "hf"
}
