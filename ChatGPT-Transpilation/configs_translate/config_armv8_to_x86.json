{
  "benchmark": "HumanEval",
  "action": "compile_and_run", 
  "model_name": "gpt-5-mini-2025-08-07",
  "max_workers": 80,
  "max_retries": 3,
  "retry_base_seconds": 2.0,
  "source_arch": "Armv8",
  "source_dataset_column": "aarch64_linux",
  "target_arch": "x86_64",
  "test_root": "../HumanEval_source",
  "clang": "clang-17",
  "compile_flags": [
    "-target", 
    "x86_64-unknown-linux-gnu", 
    "-masm=intel"
  ],
  "link_flags": [
    "-target", 
    "x86_64-unknown-linux-gnu",
    "-lm"
  ],
  "qemu": "",
  "use_qemu": false,
  "timeout_seconds": 30,
  "prompt_template": "Translate the following assembly code from {source_arch} to {target_arch}. Return ONLY the translated assembly code with no explanations.\n\n{source_code}"
}