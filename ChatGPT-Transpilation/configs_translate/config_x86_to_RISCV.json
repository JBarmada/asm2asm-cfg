{
  "benchmark": "HumanEval",
  "action": "compile_and_run", 
  "model_name": "gpt-5-mini-2025-08-07",
  "max_workers": 80,
  "max_retries": 3,
  "retry_base_seconds": 2.0,
  "source_arch": "x86_64",
  "source_dataset_column": "x86_64",
  "target_arch": "RISCV",
  "test_root": "../HumanEval_source",
  "clang": "clang-17",
  "compile_flags": ["-target", "riscv64-unknown-linux-gnu", "-march=rv64gc", "-mabi=lp64d"],
  "link_flags": ["-target", "riscv64-unknown-linux-gnu", "-march=rv64gc", "-mabi=lp64d", "-static", "-fuse-ld=lld", "-lm"],
  "qemu": "qemu-riscv64",
  "use_qemu": true,
  "timeout_seconds": 30,
  "prompt_template": "Translate the following assembly code from {source_arch} to {target_arch}. Return ONLY the translated assembly code with no explanations.\n\n{source_code}"
}