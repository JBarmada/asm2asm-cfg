{
  "benchmark": "HumanEval",
  "action": "translate_only", 
  "model_name": "gpt-5-mini-2025-08-07",
  "max_workers": 20,
  "max_retries": 3,
  "retry_base_seconds": 2.0,
  "source_arch": "RISCV",
  "source_dataset_column": "riscv64",
  "target_arch": "Armv8.4a (Apple Silicon Mac)",
  "test_root": "../HumanEval_source",
  "clang": "clang-17",
  "compile_flags": [
    "-target", 
    "arm64-apple-darwin"
  ],
  "link_flags": [
    "-target", 
    "arm64-apple-darwin"
  ],
  "qemu": "",
  "use_qemu": false,
  "timeout_seconds": 30,
  "prompt_template": "Translate the following assembly code from {source_arch} to {target_arch}. Return ONLY the translated assembly code with no explanations.\n\n{source_code}"
}