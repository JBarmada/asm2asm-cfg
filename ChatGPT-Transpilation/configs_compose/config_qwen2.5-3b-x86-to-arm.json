{
  "benchmark": "HumanEval",
  "action": "compile_and_run",

  "model_name": "Qwen-3b",
  "composer_model": "gpt-5-mini-2025-08-07",
  "composer_prompt_config": "error_cfg_dfg",

  "max_workers": 10,
  "max_retries": 3,
  "retry_base_seconds": 2.0,

  "source_arch": "x86_64",
  "source_dataset_column": "x86_64",
  "cfg_dataset_column": "x86_64",
  "dfg_dataset_column": "x86_64",

  "target_arch": "Armv8",

  "test_root": "../HumanEval_source",
  "clang": "clang-17",
  "compile_flags": [
    "-target",
    "aarch64-linux-gnu"
  ],
  "link_flags": [
    "-target",
    "aarch64-linux-gnu",
    "-static",
    "-fuse-ld=lld",
    "-lm"
  ],
  "qemu": "qemu-aarch64",
  "use_qemu": true,
  "timeout_seconds": 30,

  "prompt_template": "Translate the following assembly code from {source_arch} to {target_arch}. Return ONLY the translated assembly code with no explanations.\n\n{source_code}"
}
