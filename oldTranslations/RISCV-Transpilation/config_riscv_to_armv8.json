{
  "benchmark": "HumanEval",
  "action": "compile_and_run",
  "model_name": "gemini-3-flash-preview",
  "max_workers": 20,
  "max_retries": 3,
  "retry_base_seconds": 2.0,
  "source_arch": "RISCV",
  "source_dataset_field": "riscv64",
  "target_arch": "Armv8",
  "test_root": "../HumanEval_source",
  "clang": "clang-17",
  "compile_flags": [
    "-target", "aarch64-unknown-linux-gnu",
    "-march=armv8-a"
  ],
  "link_flags": [
    "-target", "aarch64-unknown-linux-gnu",
    "-march=armv8-a",
    "-static",
    "-fuse-ld=lld",
    "-lm"
  ],
  "qemu": "qemu-aarch64",
  "use_qemu": true,
  "timeout_seconds": 30,
  "prompt_template": "Translate the following assembly code from {source_arch} to {target_arch}. Return ONLY the translated assembly code with no explanations.\\n\\n{source_code}"
}
